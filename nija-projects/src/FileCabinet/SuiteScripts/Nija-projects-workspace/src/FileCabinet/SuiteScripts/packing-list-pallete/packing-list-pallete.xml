<?xml version="1.0"?> 
<!DOCTYPE pdf PUBLIC "-//big.faceless.org//report" "report-1.1.dtd">
<pdf>
<head>
<style type="text/css">
    body {
        font-family: Helvetica, sans-serif;
        font-size: 9pt;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        font-weight: bold;
        text-align: center;
        border: 0.2px solid black;
        padding: 5px;
        font-size: 9pt;
    }

    td {
        padding: 3px 5px;
    }

    .border {
        border: 0.2px solid black;
    }

    .label {
        font-weight: bold;
    }

    .title {
        font-size: 18pt;
        font-weight: bold;
        text-align: center;
        text-decoration: underline;
    }

    .row {
        height: 18px;
    }
</style>
</head>

<body size="A4" margin="10pt">

<!-- DYNAMIC ITEM TABLE -->
<table class="border" style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr>
                <td colspan="8" style="padding: 0; border-bottom: none;">
                    <!-- LOGO -->
                    <table style="width: 100%;">
                        <tr>
                            <td align="center" style="padding-top: 10px;">
                                <img src="https://12075805.app.netsuite.com/core/media/media.nl?id=1345&amp;c=12075805&amp;h=oxJr2CNYdwCz0TJsbbtkt6STehBgPajb40mWp8wtLfhM6v38" style="width: 600px; height: 70px;" />
                            </td>
                        </tr>
                    </table>
                    
                    <!-- TITLE -->
                    <table style="width: 100%;">
                        <tr>
                            <td class="title" align="center" style="padding-bottom: 10px;">PACKING LIST</td>
                        </tr>
                    </table>
                </td>
            </tr>
            <tr>
                <td colspan="2" class="label border" style="border-left: none;">Date:</td>
                <td colspan="1" class="border">${record.custrecord_njt_packing_list_date}</td>
                <td colspan="2" class="label border">Invoice No:</td>
                <td colspan="1" class="border">${record.custrecord_njt_packing_list_inv}</td>
                <td colspan="1" class="label border" style="white-space: nowrap;">Client Ref Order No:</td>
                <td colspan="1" class="border" style="border-right: none;">${record.custrecord_njt_packing_list_client_po}</td>
            </tr>
            <tr class="row">
                <td colspan="8" class="border" style="border-left: none; border-right: none;">&nbsp;</td>
            </tr>
            <tr style="background-color: #898989ff; white-space: nowrap;">
                <th style="width:5%;">Sl.No</th>
                <th style="width:10%;">Serial No</th>
                <th style="width:25%;">Item Description</th>
                <th style="width:10%;">Unit</th>
                <th style="width:10%;">Box No</th>
                <th style="width:15%;">Qty/Box</th>
                <th style="width:15%;">Total Box</th>
                <th style="width:10%;">Total Qty</th>
            </tr>
        </thead>

        <tbody>
        <#if record.recmachcustrecord_njt_packing_list_in_parentlin?has_content>
        <#list record.recmachcustrecord_njt_packing_list_in_parentlin as item>
            <tr class="row" style="page-break-inside: avoid;">
                <td class="border" align="center">${item_index + 1}</td>
                <td class="border" align="center">${item.custrecord_serial_no!""}</td>
                <td class="border">
                    <span style="font-size:8pt;">
                        ${item.custrecord_njt_packing_in_des!""}
                    </span>
                </td>
                <td class="border" align="center">${item.custrecord_njt_packing_list_in_unit}</td>
                <td class="border" align="center">${item.custrecord_box_no!""}</td>
                <td class="border" align="right">${item.custrecord_njt_packing_list_in_box!""}</td>
                <td class="border" align="right">${item.custrecord_njt_packing_list_in_totl!""}</td>
                <td class="border" align="right">${item.custrecord_njt_packing_list_in_totqty!""}</td>
            </tr>
        </#list>
        </#if>

            <tr class="row">
                <td colspan="8" class="border" style="border-left: none; border-right: none;">&nbsp;</td>
            </tr>
            <!-- SUMMARY SECTION & SIGNATURE -->
            <tr style="page-break-inside: avoid;">
                <td colspan="3" class="label border">Total Number of Boxes:</td>
                <td colspan="1" class="border">${record.custrecord_njt_packing_list_tota_box!""}</td>
                <td colspan="2" class="label border">Pallet No:</td>
                <td colspan="2" class="border">${record.custrecord_njt_packing_pallete!""}</td>
            </tr>
            <tr style="page-break-inside: avoid;">
                <td colspan="3" class="label border">Total Number of Bundles:</td>
                <td colspan="1" class="border">${record.custrecord_njt_toal_numberof_bundle!""}</td>
                <td colspan="2" class="label border">Pallet Dimension in MM (L*W*H):</td>
                <td colspan="2" class="border">${record.custrecord_njt_dimension_mm!""}</td>
            </tr>
            <tr style="page-break-inside: avoid;">
                <td colspan="3" class="label border">Total Net Weight (KG):</td>
                <td colspan="1" class="border">${record.custrecord_njt_total_net_weight!""}</td>
                <td colspan="2" class="label border">HS Code:</td>
                <td colspan="2" class="border">${record.custrecord_hs_code!""}</td>
            </tr>
            <tr style="page-break-inside: avoid;">
                <td colspan="3" class="label border">Total Gross Weight (KG):</td>
                <td colspan="1" class="border">${record.custrecord_njt_total_gross_weight!""}</td>
                <td colspan="2" class="label border">Country of Origin:</td>
                <td colspan="2" class="border">${record.custrecord_njt_country_of_orgin!""}</td>
            </tr>
            <tr class="row">
                <td colspan="8" class="border" style="border-left: none; border-right: none;">&nbsp;</td>
            </tr>
            <tr>
                <td colspan="8" style="padding: 0;">
                    <table style="width: 100%;">
                        <tr>
                            <td style="height:40px;"></td>
                        </tr>
                        <tr>
                            <td class="label" style="padding: 0px 5px 10px 5px;">SIGNATURE WITH STAMP:</td>
                        </tr>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>

</body>
</pdf>